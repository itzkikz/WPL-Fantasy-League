{"nodes": [{"id": "ui_src_pages_home_homepagepng_screenshot", "label": "WPL Fantasy League Homepage UI Screenshot", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "metadata": {"description": "Dark-themed mobile-first responsive dashboard for a Women's Premier League fantasy football application. Uses a 2-column grid on mobile, 4-column on desktop. Features a top header bar with WPL logo, 'WPL Fantasy' title, notification bell, and settings button. Bottom mobile navigation with 5 tabs: Home, League, My Team, H2H, Stats. Dashboard is composed of card-based widgets arranged in a grid layout with purple (#A855F7) accent color scheme and deep dark background (#120C22).", "ui_pattern": "card-dashboard", "layout": "responsive-grid-2col-mobile-4col-desktop", "theme": "dark"}}, {"id": "ui_src_pages_home_homepagepng_teamoverview", "label": "TeamOverview Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Full-width card at top of dashboard showing team name, managers, overall rank with rank change indicator, total points, and gameweek points. Tapping navigates to /my-team.", "position": "top-full-width"}}, {"id": "ui_src_pages_home_homepagepng_upcomingfixture", "label": "UpcomingFixture Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Full-width card displaying upcoming match fixtures for the user's team, showing gameweek and fixture details.", "position": "below-teamoverview-full-width"}}, {"id": "ui_src_pages_home_homepagepng_leaguestatistics", "label": "LeagueStatistics Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Half-width card showing four league stats: Total Managers (with Users icon), GW Average (indigo), Highest Points (pink), Total Teams (rose). Each stat has a colored circle icon container.", "position": "half-width-left"}}, {"id": "ui_src_pages_home_homepagepng_gameweekprogress", "label": "GameweekProgress Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Half-width card displaying current gameweek number, deadline label, and start/end date range. Includes a crown badge icon.", "position": "half-width-right"}}, {"id": "ui_src_pages_home_homepagepng_leaguestandings", "label": "LeagueStandings Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Half-width card showing top 3 teams in league standings with the user's team highlighted. Includes 'View Full' link to /standings.", "position": "half-width-left"}}, {"id": "ui_src_pages_home_homepagepng_playerspotlight", "label": "PlayerSpotlight Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Half-width card featuring a spotlighted player with photo, name, club, position, form history, gameweek points, and detailed stats.", "position": "half-width-right"}}, {"id": "ui_src_pages_home_homepagepng_topplayers", "label": "Top Players Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Card listing top scoring players of the current gameweek with name, team, position, and points.", "position": "quarter-width"}}, {"id": "ui_src_pages_home_homepagepng_bestperformers", "label": "Best Performers Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Card listing best performing players of the entire season with name, team, position, and total points.", "position": "quarter-width"}}, {"id": "ui_src_pages_home_homepagepng_recentgameweeks", "label": "Recent Gameweeks Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Card showing recent gameweek performance history with labeled points per gameweek (e.g. GW1, GW2, etc.).", "position": "quarter-width"}}, {"id": "ui_src_pages_home_homepagepng_pointsbreakdown", "label": "Points Breakdown Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Card showing total points and a breakdown by category: Goals (green), Assists (blue), Clean Sheets (indigo), Appearance (yellow), Defensive (teal), Penalty Save (emerald), Saves (violet), Yellow Cards (amber), Red Cards (red), Penalty Miss (orange). Each category shows value and percentage bar.", "position": "quarter-width"}}, {"id": "ui_src_pages_home_homepagepng_seasonstats", "label": "Season Stats Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Card showing four season statistics: Total Points (Target icon), Avg Points/GW (Activity icon), Highest GW (ShieldCheck icon), Overall Rank (Square icon).", "position": "quarter-width"}}, {"id": "ui_src_pages_home_homepagepng_teamformation", "label": "Team Formation Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Full-width card displaying the user's squad formation visually (e.g. 4-4-2) with count of goalkeepers, defenders, midfielders, and forwards.", "position": "full-width"}}, {"id": "ui_src_pages_home_homepagepng_squadvalue", "label": "Squad Value Card", "file_type": "image", "source_file": "homepage.png", "source_location": null, "source_url": null, "metadata": {"description": "Half-width card showing squad financial information: total value, remaining bank, and team value in GBP millions.", "position": "half-width"}}, {"id": "ui_src_p